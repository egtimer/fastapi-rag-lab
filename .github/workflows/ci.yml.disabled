# Actions pinned by SHA for supply chain safety
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  lint:
    name: Lint and format check
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@cec208311dfd045dd5311c1add060b2062131d57  # v8.0.0
        with:
          python-version: "3.12"
      - run: uv sync --extra dev
      - run: uv run ruff check .
      - run: uv run ruff format --check .

  # Integration tests run locally with `pytest` against real Ollama + Qdrant.
  # See README testing section. They are excluded from CI to keep builds fast
  # and avoid spinning up GPU-capable runners. The ADR for this trade-off
  # will be added in Phase 5.
